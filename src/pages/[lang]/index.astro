---
import AboutMe from "@components/Sections/AboutMe/AboutMe.astro";
import HeroSection from "@components/Sections/Hero/HeroSection.astro";
import Spacer from "@components/Sections/Spacer/Spacer";
import TechStack from "@components/Sections/TechStack/TechStack.astro";
import ProjectGrid from "@components/Sections/ProjectGrid/ProjectGrid.astro";
import Contact from "@components/Sections/Contact";
import RootLayout from "@layouts/RootLayout.astro";
import ExperienceSection from "@components/Sections/Experience/ExperienceSection.astro";
import { languages, defaultLang } from "@i18n/ui";
import { useTranslations } from "@i18n/utils";

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = useTranslations(lang as any);
const title = t('nav.home');
---

<RootLayout title={title} enableHeader enableFooter>
  <HeroSection lang={lang} />
  <Spacer lang={lang} variant="absolute" enableScroll />
  <AboutMe lang={lang} />
  <Spacer lang={lang} variant="absolute" enableScroll />
  <TechStack lang={lang} />
  <ExperienceSection lang={lang} />
  <ProjectGrid lang={lang} />
  <Contact lang={lang} client:load />
</RootLayout>
