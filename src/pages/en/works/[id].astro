---
import { getEntry } from "astro:content";
import RootLayout from "../../../layouts/RootLayout.astro";
import { Image } from "astro:assets";

export async function getStaticPaths() {
  const enProjects = await getEntry("projects", "en");
  return enProjects.data.items.map((project: any) => ({
    params: { id: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const hasImages = project.images && project.images.length > 0;
---

<RootLayout title={`${project.title} | Cuong Vu`}>
  <div
    class="flex flex-col md:flex-row min-h-screen w-full text-gray-100 bg-[#0a0a0a] md:h-screen md:overflow-hidden"
  >
    <!-- Left Column: Gallery (Only if has images) -->
    {hasImages && (
      <div
        class="gallery-container w-full md:w-1/3 h-auto md:h-full md:overflow-y-auto overflow-x-hidden p-6 md:p-8 space-y-8 md:space-y-12 flex-shrink-0 scrollbar-hide border-b md:border-b-0 md:border-r border-gray-800"
      >
        <a
          href="/en/"
          class="inline-flex items-center text-sm font-medium text-gray-400 hover:text-white mb-8 transition-colors md:hidden"
        >
          &larr; Back to Home
        </a>
        {
          project.images.map((img: any, i: number) => (
            <div class="w-full relative rounded-2xl overflow-hidden bg-gray-900 project-image-wrapper shadow-sm">
              <Image
                src={img}
                alt={`${project.title} Image ${i + 1}`}
                class="w-full h-auto object-cover transform scale-110 project-image"
                loading={i === 0 ? "eager" : "lazy"}
              />
            </div>
          ))
        }
      </div>
    )}

    <!-- Right Column: Content -->
    <div
      class:list={[
        "h-auto md:h-full md:overflow-y-auto p-6 md:p-16 lg:p-24 flex flex-col pt-12 md:pt-32",
        hasImages ? "w-full md:w-2/3" : "w-full max-w-5xl mx-auto"
      ]}
    >
      <a
        href="/en/"
        class="anim-item-detail hidden md:inline-flex items-center text-sm font-medium text-gray-400 hover:text-white mb-12 transition-colors self-start"
      >
        &larr; Back to Home
      </a>

      {!hasImages && (
         <a
          href="/en/"
          class="inline-flex items-center text-sm font-medium text-gray-400 hover:text-white mb-8 transition-colors md:hidden"
        >
          &larr; Back to Home
        </a>
      )}

      <header class="project-header max-w-4xl">
        <div
          class="anim-item-detail flex items-center gap-4 text-sm text-gray-500 mb-6 uppercase tracking-wider"
        >
          <span>{project.category}</span>
          <span>&bull;</span>
          <span>{project.year}</span>
        </div>
        
        <h1
          class="text-4xl md:text-6xl lg:text-7xl font-bold mb-8 leading-tight pb-4 text-white"
          transition:name={`project-title-${project.id}`}
        >
          {project.title}
        </h1>

        {
          project.tags && project.tags.length > 0 && (
            <div class="anim-item-detail flex flex-wrap gap-2 mb-8">
              {project.tags.map((tag: string) => (
                <span class="px-3 py-1 bg-gray-900 rounded-full text-xs font-medium text-gray-400">
                  {tag}
                </span>
              ))}
            </div>
          )
        }

        {
          (project.role || project.teamSize || project.duration) && (
            <div class="anim-item-detail grid grid-cols-2 lg:grid-cols-3 gap-6 mb-12 py-8 border-y border-gray-800">
              {project.role && (
                <div>
                  <h3 class="text-xs font-semibold text-white uppercase tracking-wider mb-2">
                    Role
                  </h3>
                  <p class="text-gray-400 text-sm md:text-base">
                    {project.role}
                  </p>
                </div>
              )}
              {project.teamSize && (
                <div>
                  <h3 class="text-xs font-semibold text-white uppercase tracking-wider mb-2">
                    Team Size
                  </h3>
                  <p class="text-gray-400 text-sm md:text-base">
                    {project.teamSize}
                  </p>
                </div>
              )}
              {project.duration && (
                <div>
                  <h3 class="text-xs font-semibold text-white uppercase tracking-wider mb-2">
                    Duration
                  </h3>
                  <p class="text-gray-400 text-sm md:text-base">
                    {project.duration}
                  </p>
                </div>
              )}
            </div>
          )
        }

        <div
          class="anim-item-detail prose prose-lg prose-invert max-w-none mb-12 text-gray-400"
        >
          {
            project.goals ? (
              <div class="mb-10">
                <h2 class="text-2xl font-bold text-white mb-4">
                  Overview / Goals
                </h2>
                <p class="text-xl md:text-2xl leading-relaxed whitespace-pre-line mb-6">
                  {project.description}
                </p>
                <p class="text-lg leading-relaxed whitespace-pre-line text-gray-400">
                  {project.goals}
                </p>
              </div>
            ) : (
              <p class="text-xl md:text-2xl leading-relaxed whitespace-pre-line">
                {project.description}
              </p>
            )
          }

          {
            project.features && project.features.length > 0 && (
              <div>
                <h2 class="text-2xl font-bold text-white mb-4">Key Features</h2>
                <ul class="list-disc pl-5 space-y-2 text-lg text-gray-400">
                  {project.features.map((feature: string) => (
                    <li>{feature}</li>
                  ))}
                </ul>
              </div>
            )
          }
        </div>

        {
          project.links && (project.links.github || project.links.demo) && (
            <div class="anim-item-detail flex flex-wrap gap-4 mt-8">
              {project.links.github && (
                <a
                  href={project.links.github}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="px-8 py-4 bg-white text-black rounded-full font-medium hover:scale-105 transition-transform shadow-lg"
                >
                  View Source
                </a>
              )}
              {project.links.demo && (
                <a
                  href={project.links.demo}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="px-8 py-4 border-2 border-white rounded-full font-medium hover:bg-white hover:text-black transition-all"
                >
                  Visit Live Site
                </a>
              )}
            </div>
          )
        }
      </header>
    </div>
  </div>
</RootLayout>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  function initDetailAnimations() {
    gsap.fromTo(
      ".anim-item-detail",
      { y: 30, opacity: 0 },
      {
        y: 0,
        opacity: 1,
        duration: 1,
        stagger: 0.1,
        ease: "power3.out",
        delay: 0.2,
      }
    );

    let mm = gsap.matchMedia();

    const setupImageAnimations = (scrollerSelector: string | null) => {
      const images = document.querySelectorAll(".project-image-wrapper");
      images.forEach((wrapper) => {
        const img = wrapper.querySelector(".project-image");

        const scrollConfig: any = {
          trigger: wrapper,
          start: "top 90%",
          toggleActions: "play none none reverse",
        };

        if (scrollerSelector) {
          scrollConfig.scroller = scrollerSelector;
        }

        gsap.fromTo(
          wrapper,
          { opacity: 0, y: 100 },
          {
            opacity: 1,
            y: 0,
            duration: 1.6,
            ease: "expo.out",
            scrollTrigger: scrollConfig,
          }
        );

        if (img) {
          gsap.fromTo(
            img,
            { scale: 1.3 },
            {
              scale: 1,
              duration: 1.6,
              ease: "expo.out",
              scrollTrigger: scrollConfig,
            }
          );
        }
      });
    };

    mm.add("(min-width: 768px)", () => {
      const hasGallery = !!document.querySelector(".gallery-container");
      if (hasGallery) {
        setupImageAnimations(".gallery-container");
      } else {
        setupImageAnimations(null);
      }
    });

    mm.add("(max-width: 767px)", () => {
      setupImageAnimations(null);
    });
  }

  document.addEventListener("astro:page-load", initDetailAnimations);
  initDetailAnimations();
</script>
