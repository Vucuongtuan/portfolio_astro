---
---
<div id="custom-cursor" class="custom-cursor">
  <div class="cursor-dot"></div>
  <div class="cursor-outline"></div>
</div>

<script>
  import { gsap } from 'gsap';

  function initCursor() {
    const cursor = document.getElementById('custom-cursor');
    if (!cursor) return;

    const dot = cursor.querySelector('.cursor-dot');
    const outline = cursor.querySelector('.cursor-outline');

    const xToDot = gsap.quickTo(dot, "x", { duration: 0.1, ease: "power3" });
    const yToDot = gsap.quickTo(dot, "y", { duration: 0.1, ease: "power3" });
    
    const xToOutline = gsap.quickTo(outline, "x", { duration: 0.5, ease: "power3" });
    const yToOutline = gsap.quickTo(outline, "y", { duration: 0.5, ease: "power3" });

    window.addEventListener("mousemove", (e) => {
      xToDot(e.clientX);
      yToDot(e.clientY);
      xToOutline(e.clientX);
      yToOutline(e.clientY);
    });

    // Hover effects
    const targets = document.querySelectorAll('a, button, [data-magnetic]');
    targets.forEach(target => {
      target.addEventListener('mouseenter', () => {
        gsap.to(outline, { scale: 2, duration: 0.3 });
        gsap.to(dot, { scale: 0, duration: 0.3 });
      });
      target.addEventListener('mouseleave', () => {
        gsap.to(outline, { scale: 1, duration: 0.3 });
        gsap.to(dot, { scale: 1, duration: 0.3 });
      });
    });
  }

  document.addEventListener('astro:page-load', initCursor);
</script>

<style is:global>
  .custom-cursor {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 9999;
  }

  .cursor-dot {
    position: absolute;
    width: 8px;
    height: 8px;
    background: white;
    border-radius: 50%;
    transform: translate(-50%, -50%);
    mix-blend-mode: difference;
  }

  .cursor-outline {
    position: absolute;
    width: 40px;
    height: 40px;
    border: 1px solid rgba(255, 255, 255, 0.5);
    border-radius: 50%;
    transform: translate(-50%, -50%);
    mix-blend-mode: difference;
  }

  /* Ẩn con trỏ mặc định trên desktop */
  @media (pointer: fine) {
    body, a, button {
      cursor: none !important;
    }
  }
</style>
