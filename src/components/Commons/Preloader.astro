---
---
<div id="preloader" class="preloader">
  <div class="preloader-bg"></div>
  <div class="preloader-content">
    <span class="preloader-percent">0</span>
    <div class="preloader-bar"></div>
  </div>
</div>

<script>
  import { gsap } from 'gsap';

  function initPreloader() {
    const preloader = document.getElementById('preloader');
    if (!preloader) return;

    const percentEl = preloader.querySelector('.preloader-percent');
    const bar = preloader.querySelector('.preloader-bar');
    const bg = preloader.querySelector('.preloader-bg');
    
    let progress = { value: 0 };

    // Set initial state
    gsap.set(preloader, { display: "flex" });

    gsap.to(progress, {
      value: 100,
      duration: 2.2,
      ease: "power3.inOut",
      onUpdate: () => {
        if (percentEl) percentEl.textContent = Math.round(progress.value).toString();
        if (bar) gsap.set(bar, { scaleX: progress.value / 100 });
      },
      onComplete: () => {
        const tl = gsap.timeline({
          onComplete: () => {
            // XÓA CLASS IS-LOADING ĐỂ HIỆN NỘI DUNG
            document.body.classList.remove('is-loading');
            
            // PHÁT SỰ KIỆN KHI PRELOADER KẾT THÚC
            window.dispatchEvent(new CustomEvent('loader-finished'));
            gsap.set(preloader, { display: "none" });
          }
        });

        tl.to([percentEl, bar], { opacity: 0, y: -20, duration: 0.4, ease: "power2.in" })
          .to(bg, {
            clipPath: "inset(0 0 100% 0)",
            duration: 1.2,
            ease: "expo.inOut"
          });
      }
    });
  }

  // Chạy khi trang load lần đầu
  window.addEventListener('load', initPreloader);

  // Hỗ trợ View Transitions: Nếu chuyển trang thì không hiện preloader nữa (hoặc hiện ngắn hơn)
  document.addEventListener('astro:after-swap', () => {
    const preloader = document.getElementById('preloader');
    if (preloader) preloader.style.display = 'none';
  });
</script>

<style>
  .preloader {
    position: fixed;
    inset: 0;
    z-index: 10000;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-family: monospace;
    pointer-events: none; /* Tránh cản trở tương tác nếu bị lỗi */
  }

  .preloader-bg {
    position: absolute;
    inset: 0;
    background: #0a0a0a;
    clip-path: inset(0 0 0 0);
  }

  .preloader-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    width: 200px;
  }

  .preloader-percent {
    font-size: 2.5rem;
    font-weight: bold;
    letter-spacing: -0.05em;
  }

  .preloader-bar {
    width: 100%;
    height: 1px;
    background: white;
    transform: scaleX(0);
    transform-origin: left center;
    opacity: 0.3;
  }
</style>
