---
interface Props {
  text: string;
  tag?: "h1" | "h2" | "h3";
  className?: string;
  charClassName?: string;
  animationType?: "reveal" | "stagger" | "parallax";
}

const { 
  text, 
  tag: Tag = "h2", 
  className = "", 
  charClassName = "",
  animationType = "reveal" 
} = Astro.props;

// Tách chuỗi thành mảng các ký tự, giữ nguyên khoảng trắng
const chars = text.split("");
---

<Tag class:list={["animated-title", className]} data-animation={animationType}>
  {
    chars.map((char) => (
      <span class:list={["char inline-block", charClassName]}>
        {char === " " ? "\u00A0" : char}
      </span>
    ))
  }
</Tag>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  function initTitleAnimations() {
    const titles = document.querySelectorAll(".animated-title");

    titles.forEach((title) => {
      const chars = title.querySelectorAll(".char");
      const animationType = title.getAttribute("data-animation");

      if (chars.length === 0) return;

      // Xóa các trigger cũ nếu có để tránh lỗi View Transitions
      ScrollTrigger.getAll().forEach(st => {
        if (st.vars.trigger === title) st.kill();
      });

      if (animationType === "reveal") {
        gsap.set(chars, { 
          yPercent: 130, 
          opacity: 0,
          rotateZ: 10
        });

        gsap.to(chars, {
          yPercent: 0,
          opacity: 1,
          rotateZ: 0,
          duration: 1.2,
          stagger: 0.03,
          ease: "expo.out",
          scrollTrigger: {
            trigger: title,
            start: "top 85%",
            toggleActions: "play none none reverse",
          }
        });
      } else if (animationType === "parallax") {
        gsap.to(title, {
          yPercent: 20,
          ease: "none",
          scrollTrigger: {
            trigger: title,
            start: "top bottom",
            end: "bottom top",
            scrub: true,
          }
        });
      }
    });
  }

  document.addEventListener("astro:page-load", initTitleAnimations);
  initTitleAnimations();
</script>

<style>
  .animated-title {
    overflow: hidden;
    display: block;
  }
  
  .char {
    display: inline-block;
    will-change: transform, opacity;
  }
</style>
