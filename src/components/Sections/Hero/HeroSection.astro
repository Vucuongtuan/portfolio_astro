---
import { useTranslations } from "@i18n/utils";
import type { Locale } from "@i18n/ui";
import st from "./hero-section.module.scss";
import clsx from "clsx";

interface Props {
  lang: Locale;
  title?: string;
  fullName?: string;
  showInfo?: boolean;
}

const { lang, title, fullName, showInfo = true } = Astro.props;

const t = useTranslations(lang);

const mainText = title || t("landing.title") || "CUONG";
const nameInInfo = fullName || t("landing.name") || "VU TUAN CUONG";
const mainTextChars = mainText.split("");
---

<section
  class={clsx(st.section, "")}
  id="hero-section"
  data-section="Hero"
  data-theme="light"
>
  {
    showInfo && (
      <div class={clsx(st.infoRow, "w-full")}>
        <div
          class={clsx(
            st.infoItem,
            "flex flex-col hero-info-item opacity-0 translate-y-4"
          )}
        >
          <span class={st.infoLabel}>Name</span>
          <span class={st.infoValue}>{nameInInfo}</span>
        </div>

        <div
          class={clsx(
            st.infoItem,
            "flex flex-col hero-info-item opacity-0 translate-y-4"
          )}
        >
          <span class={st.infoLabel}>Role</span>
          <span class={st.infoValue}>{t("hero.role")}</span>
        </div>
        <div
          class={clsx(
            st.infoItem,
            "flex flex-col hero-info-item opacity-0 translate-y-4"
          )}
        >
          <span class={st.infoLabel}>Location</span>
          <span class={st.infoValue}>{t("landing.location")}</span>
        </div>
        <div
          class={clsx(
            st.infoItem,
            "flex flex-col hero-info-item opacity-0 translate-y-4"
          )}
        >
          <span class={st.infoLabel}>Status</span>
          <span class={st.infoValue}>Available</span>
        </div>
      </div>
    )
  }

  <div class={clsx(st.descRow, "w-full")}>
    <p class={clsx(st.descCol, "hero-desc-item opacity-0 translate-y-4")}>
      {t("hero.desc")}
    </p>
    <p class={clsx(st.descCol, "hero-desc-item opacity-0 translate-y-4")}>
      {t("landing.role")}
    </p>
  </div>

  <div class={clsx(st.nameWrapper, "w-full overflow-hidden")}>
    <h2 class={clsx(st.name, "select-none")} id="hero-main-title">
      {
        mainTextChars.map((char) => (
          <span class={clsx(st.nameChar, "inline-block")} data-cursor="chars">
            {char === " " ? "\u00A0" : char}
          </span>
        ))
      }
    </h2>
  </div>
</section>

<script>
  import gsap from "gsap";

  function initHeroAnimation() {
    const section = document.getElementById("hero-section");
    if (!section) return;

    const chars = section.querySelectorAll(".hero-char");
    const infoItems = section.querySelectorAll(".hero-info-item");
    const descItems = section.querySelectorAll(".hero-desc-item");

    // Đặt trạng thái ban đầu bằng GSAP (thay vì CSS) để tránh bị mất chữ nếu script lỗi
    gsap.set(chars, { yPercent: 120, opacity: 0 });

    const startAnimation = () => {
      // Main Title
      gsap.to(chars, {
        yPercent: 0,
        opacity: 1,
        duration: 1.2,
        stagger: 0.03,
        ease: "expo.out",
        delay: 0.2,
      });

      // Info Items
      if (infoItems.length > 0) {
        gsap.to(infoItems, {
          y: 0,
          opacity: 1,
          duration: 0.8,
          stagger: 0.1,
          ease: "power3.out",
          delay: 0.6,
        });
      }

      // Description
      if (descItems.length > 0) {
        gsap.to(descItems, {
          y: 0,
          opacity: 1,
          duration: 0.8,
          stagger: 0.1,
          ease: "power3.out",
          delay: 0.9,
        });
      }
    };

    // Kiểm tra Preloader
    const preloader = document.getElementById("preloader");
    // Nếu preloader đang hiển thị (chưa kết thúc)
    if (preloader && window.getComputedStyle(preloader).display !== "none") {
      window.addEventListener("loader-finished", startAnimation, {
        once: true,
      });
    } else {
      // Nếu không có preloader hoặc đã xong rồi thì chạy luôn
      startAnimation();
    }
  }

  // Khởi tạo
  document.addEventListener("astro:page-load", initHeroAnimation);
  // Chạy lần đầu nếu không dùng View Transitions hoặc load trang trực tiếp
  initHeroAnimation();
</script>
