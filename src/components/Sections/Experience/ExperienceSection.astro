---
import { getEntry } from "astro:content";
import type { Locale } from "../../../i18n/ui";
import { useTranslations } from "../../../i18n/utils";
import st from './experience-section.module.scss';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const experienceData = await getEntry("experience", lang);
const t = useTranslations(lang);

const data = experienceData?.data;
---

{data && (
<section id="experience-container" class={st.experienceContainer} data-section="Experience" data-theme="dark">
    <!-- Grid Background -->
    <div class={st.gridBackground}></div>
    
    <div class="relative z-10 w-full">
        <header class={st.sectionHeader}>
            <div class="flex flex-col">
                <span class={st.sectionTag}>
                    PROFESSIONAL HISTORY / 02
                </span>
                <h2 class={`${st.mainTitle} anim-title`}>
                    {data.title}
                </h2>
            </div>
        </header>

        <div class="w-full experience-list">
            <div class={st.tableHeader}>
                <div class="w-1/4">{data.listHeader?.period}</div>
                <div class="w-1/2">{data.listHeader?.organization}</div>
                <div class="w-1/4 text-right">{data.listHeader?.roleLocation}</div>
            </div>

            {data.items?.map((exp) => (
                <article class={`${st.listItem} anim-item`}>
                    <div class={st.itemContent}>
                        
                        <div class={st.itemPeriod}>
                            <span class={st.periodBadge}>
                                {exp.period}
                            </span>
                        </div>
                        
                        <div class={st.itemCompanyContainer}>
                            <h3 class={st.itemCompany}>
                                {exp.company}
                            </h3>
                        </div>
                        
                        <div class={st.itemMeta}>
                            <div class={st.itemRoleInfo}>
                                <div class={st.roleTitle}>{exp.role}</div>
                                <div class={st.roleLocation}>{exp.location}</div>
                            </div>
                            <span class={`material-icons ${st.itemArrow}`}>arrow_outward</span>
                        </div>
                    </div>
                </article>
            ))}
        </div>
    </div>
</section>
)}

<script>
    import gsap from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    if (typeof window !== "undefined") {
        gsap.registerPlugin(ScrollTrigger);
    }

    function initExperienceAnimation() {
        const container = document.getElementById("experience-container");
        if (!container) return;

        const title = container.querySelector(".anim-title");
        if (title) {
            gsap.fromTo(title, 
                { y: 50, opacity: 0 },
                {
                    y: 0,
                    opacity: 1,
                    duration: 1,
                    ease: "power3.out",
                    scrollTrigger: {
                        trigger: title,
                        start: "top 85%",
                        toggleActions: "play none none reverse",
                    },
                }
            );
        }

        const items = container.querySelectorAll(".anim-item");
        if (items.length > 0) {
            gsap.fromTo(items,
                { y: 30, opacity: 0 },
                {
                    y: 0,
                    opacity: 1,
                    duration: 0.8,
                    stagger: 0.1,
                    ease: "power2.out",
                    scrollTrigger: {
                        trigger: container.querySelector(".experience-list"),
                        start: "top 80%",
                        toggleActions: "play none none reverse",
                    },
                }
            );
        }
    }

    document.addEventListener("astro:page-load", initExperienceAnimation);
    initExperienceAnimation();
</script>

<style is:global>
    .anim-title, .anim-item {
        will-change: transform, opacity;
    }
</style>
